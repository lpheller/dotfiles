#!/usr/bin/env bash

p() {
  local dir
  dir=$(ls ~/Projects | fzf +s) && cd ~/Projects/"$dir"
}


function silent() {
  "$@" >&/dev/null
}

function tinker() {
  if [ -z "$1" ]; then
    php artisan tinker
  else
    php artisan tinker --execute="dd($1);"
  fi
}

function pw:secret {
  pw=$(php artisan tinker --execute="echo bcrypt('secret')")
  echo "$pw" | pbcopy && echo "secret copied to clipboard"
}

function lupdater {
  local bin=~/Projects/laravel-updater/bin/updater
  if [[ ! -f "$bin" ]]; then
    echo "laravel-updater not found. Run:"
    echo "  git clone https://github.com/lpheller/laravel-updater ~/Projects/laravel-updater"
    return 1
  fi
  php "$bin" "$@"
}

